# --- Email delivery for the contact form (/api/contact) ---
# Get a key at https://resend.com (free tier available).
# If absent, submissions are logged to the server console in dev (no email sent).
RESEND_API_KEY=

# Verified sender address in Resend. Use onboarding@resend.dev for testing,
# or a verified domain address like no-reply@bigadtruck.com in production.
CONTACT_FROM_EMAIL=onboarding@resend.dev

# Where lead notifications are delivered.
CONTACT_TO_EMAIL=vivek@bigadtruck.com

# Public site URL (used for canonical URLs, sitemap, OG images).
NEXT_PUBLIC_SITE_URL=https://bigadtruck.com

# --- AI assistant ("Truck") on the site (/api/chat) ---
# Anthropic API key — get one at https://console.anthropic.com.
# If absent, the chat widget still appears but politely points visitors to
# email/phone instead of answering. Captured leads route to CONTACT_TO_EMAIL.
ANTHROPIC_API_KEY=

# --- Sanity CMS (OPTIONAL) ---
# Leave blank and the site renders from the typed files in /content.
# Set these to manage content at /studio. Create a project at https://sanity.io.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Optional write token (only needed to run the seed import script).
SANITY_API_WRITE_TOKEN=
